<Window x:Class="DroneServiceApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DroneServiceApplication"
        mc:Ignorable="d"
        Title="Icarus Drone Service Application" 
        Height="920" 
        Width="1200" 
        WindowStartupLocation="CenterScreen" 
        Background="#DCE3EC">
    
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F3557"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DCE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ListViewHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        </Window.Resources>
            
        <DockPanel LastChildFill="True">
            
        <Border DockPanel.Dock="Bottom"
                Background="#223A59"
                Height="46"
                Margin="18,0,18,18"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Ellipse Width="12" 
                        Height="12" 
                        Fill="#22C55E" 
                        Margin="0,0,12,0"/>
                <TextBlock x:Name="txtStatus" 
                    Text="Items added successfully."
                    Foreground="White"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
                    
            <Grid Margin="18,14,18,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Icarus Drone Service Application"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F3558"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.2*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                    <TextBlock Text="Client Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtClientName" Style="{StaticResource InputTextBoxStyle}" Text=""/>

                                    <TextBlock Text="Drone Model" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtDroneModel" Style="{StaticResource InputTextBoxStyle}" Text=""/>
                                    

                                    <TextBlock Text="Service Problem" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtServiceProblem" 
                                             Height="84" 
                                             FontSize="14" 
                                             Padding="10,8"
                                             Background="White"
                                             BorderBrush="#D5DCE5"
                                             BorderThickness="1"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Margin="0,0,0,18"/>

                                    <TextBlock Text="Service Cost" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Orientation="Horizontal" >
                                        <Border Width="36" 
                                                Height="38" 
                                                Background="White" 
                                                BorderBrush="#D5DCE5" 
                                                BorderThickness="1"
                                                CornerRadius="3,0,0,3"> 
                                            <TextBlock Text="$"
                                                FontWeight="SemiBold"
                                                Foreground="#475569"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBox x:Name="txtServiceCost" 
                                                 Width="150" 
                                                 Height="38" 
                                                 FontSize="14"
                                                 Padding="10,4"
                                                 Background="White"
                                                 BorderBrush="#D5DCE5"
                                                 BorderThickness="1"
                                                 VerticalContentAlignment="Center" 
                                                 PreviewTextInput="txtServiceCost_PreviewTextInput"
                                                 LostFocus="txtServiceCost_LostFocus"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Service Tag" Style="{StaticResource FieldLabelStyle}"/>

                                    <Grid Width="100" Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBox x:Name="txtServiceTag" 
                                             Grid.Column="0"
                                             Height="38" 
                                             FontSize="14"
                                             Text="100"
                                             VerticalContentAlignment="Center" 
                                             HorizontalContentAlignment="Center"
                                             BorderBrush="#D5DCE5"
                                             BorderThickness="1"
                                             TextChanged="txtServiceTag_TextChanged"/>
                                        
                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <RepeatButton Grid.Row="0" 
                                                      Content="▲" 
                                                      FontSize="10" 
                                                      BorderBrush="#D5DCE5" 
                                                      BorderThickness="1,1,1,0"/>
                                            <RepeatButton Grid.Row="1"
                                                      Content="▼"
                                                      FontSize="10" 
                                                      BorderBrush="#D5DCE5" 
                                                      BorderThickness="1,0,1,1"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}"/>
                                    <RadioButton x:Name="rbRegular"
                                                 Content="Regular"
                                                 GroupName="PriorityGroup"
                                                 Margin="0,2,0,8"
                                                 FontSize="14"/>
                                    <RadioButton x:Name="rbExpress"
                                                 Content="Express (+15%)"
                                                 GroupName="PriorityGroup"
                                                 Margin="0,0,0,24"
                                                 FontSize="14"
                                                 IsChecked="True"/>

                                    <Button x:Name="btnAddNewItem"
                                            Content="Add New Item"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Background="#2F80ED"
                                            Click="AddNewItem"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0">
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="btnProcessRegular"
                                    DockPanel.Dock="Bottom"
                                    Content="Process Regular"
                                    Width="150"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#14C84A"
                                    Click="btnProcessRegular_Click"/>

                                    <TextBlock Text="Regular Queue" 
                                           Style="{StaticResource SectionTitleStyle}"
                                           DockPanel.Dock="Top"/>

                                    <ListView x:Name="lvRegularService"
                                          Height="180"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          MouseUp="lvRegularService_MouseUp">
                                        <ListView.Resources>
                                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ListViewHeaderStyle}"/>
                                        </ListView.Resources>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Client Name"
                                                        Width="95"
                                                        DisplayMemberBinding="{Binding ClientName}"/>
                                                <GridViewColumn Header="Drone Model"
                                                        Width="95"
                                                        DisplayMemberBinding="{Binding Model}"/>
                                                <GridViewColumn Header="Problem"
                                                        Width="95"
                                                        DisplayMemberBinding="{Binding ServiceProblem}"/>
                                                <GridViewColumn Header="Cost"
                                                        Width="60"
                                                        DisplayMemberBinding="{Binding ServiceCostFormatted}"/>
                                                <GridViewColumn Header="Tag"
                                                        Width="45"
                                                        DisplayMemberBinding="{Binding ServiceTag}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DockPanel>
                            </Border>





                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="btnProcessExpress"
                                            DockPanel.Dock="Bottom"
                                            Content="Process Express"
                                            Width="150"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Background="#F4C20D"
                                            Click="btnProcessExpress_Click"/>

                                    <TextBlock Text="Express Queue"
                                               Style="{StaticResource SectionTitleStyle}"
                                               DockPanel.Dock="Top"/>

                                    <ListView   x:Name="lvExpressService"
                                                Height="180"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                MouseUp="lvExpressService_MouseUp">
                                        <ListView.Resources>
                                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ListViewHeaderStyle}"/>
                                        </ListView.Resources>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Client Name"
                                            Width="95"
                                            DisplayMemberBinding="{Binding ClientName}"/>
                                                <GridViewColumn Header="Drone Model"
                                            Width="95"
                                            DisplayMemberBinding="{Binding Model}"/>
                                                <GridViewColumn Header="Problem"
                                            Width="95"
                                            DisplayMemberBinding="{Binding ServiceProblem}"/>
                                                <GridViewColumn Header="Cost"
                                            Width="60"
                                            DisplayMemberBinding="{Binding ServiceCostFormatted}"/>
                                                <GridViewColumn Header="Tag"
                                            Width="45"
                                            DisplayMemberBinding="{Binding ServiceTag}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DockPanel>
                            </Border>
                        </Grid>


                        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Finished Services"
                                           Style="{StaticResource SectionTitleStyle}"
                                           DockPanel.Dock="Top"/>

                                <TextBlock Text="Double click to remove after payment"
                                       Foreground="#9CA3AF"
                                       FontStyle="Italic"
                                       Margin="0,10,0,0"
                                       DockPanel.Dock="Bottom"/>

                                <ListBox x:Name="lstFinishedServices"
                                         Height="110"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MouseDoubleClick="lstFinishedServices_MouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Window>
